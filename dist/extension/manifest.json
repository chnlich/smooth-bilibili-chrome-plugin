{
  "manifest_version": 3,
  "name": "Bilibili 桌面网页抗卡",
  "version": "1.0.0",
  "description": "直播原生播放延迟连续性与视频原生 120 秒缓存提示增强",
  "minimum_chrome_version": "120",
  "permissions": [
    "storage",
    "unlimitedStorage"
  ],
  "host_permissions": [],
  "action": {
    "default_title": "Bilibili 抗卡设置",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://live.bilibili.com/*",
        "https://www.bilibili.com/*"
      ],
      "js": [
        "source-buffer-shim.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://live.bilibili.com/*",
        "https://www.bilibili.com/*"
      ],
      "js": [
        "main-bridge.js"
      ],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": [
        "https://live.bilibili.com/*",
        "https://www.bilibili.com/*"
      ],
      "js": [
        "controller.js"
      ],
      "run_at": "document_start",
      "all_frames": false,
      "world": "ISOLATED"
    }
  ]
}
